{
  "name": "microservice-kg",
  "version": "0.1.2",
  "description": "Consolidated microservice knowledge graph generator for multi-repo workspaces, with MCP support for agentic coding",
  "type": "module",
  "files": [
    "src",
    "docs/images/inter-service-example.png",
    "docs/images/dependency-neighborhood-example.png",
    "docs/images/intra-service-workflow-example.png",
    "docs/images/obsidian-graph-view.png",
    "README.md",
    "LICENSE"
  ],
  "bin": {
    "microservice-kg": "./src/cli.mjs",
    "microservice-kg-mcp": "./src/mcp-server.mjs"
  },
  "scripts": {
    "analyze": "node ./src/cli.mjs analyze",
    "start": "node ./src/cli.mjs",
    "mcp": "node ./src/mcp-server.mjs",
    "pack:check": "npm pack --dry-run",
    "build:github-package": "node ./scripts/build-github-package.mjs"
  },
  "keywords": [
    "microservices",
    "knowledge-graph",
    "architecture",
    "java",
    "spring",
    "mcp",
    "agentic-coding",
    "dependency-graph",
    "static-analysis"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pawarss1/microservice-kg.git"
  },
  "bugs": {
    "url": "https://github.com/pawarss1/microservice-kg/issues"
  },
  "homepage": "https://github.com/pawarss1/microservice-kg#readme",
  "engines": {
    "node": ">=20"
  }
}
